# Copy this file to .env and fill in real values. Never commit .env itself.

SECRET_KEY=change-me
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Comma-separated list of origins trusted for unsafe (POST/PUT/...) requests
# carrying CSRF cookies, e.g. https://app.example.com. Only needed in
# production (DEBUG=False) if you rely on session/cookie auth in addition to
# JWT — required by Django even so when DEBUG=False and the app sits behind
# a reverse proxy on a real domain.
CSRF_TRUSTED_ORIGINS=

# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=change-me

DB_NAME=fakerni
DB_USER=fakerni_user
DB_PASSWORD=change-me
DB_HOST=localhost
DB_PORT=5432

# Used for the Channels layer (real-time WebSocket fan-out across workers).
# Leave unset for local dev (falls back to single-process in-memory layer).
REDIS_URL=redis://localhost:6379

EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend

# =====================================================
# MONITORING
# =====================================================

# Log verbosity for Django's logging config (DEBUG, INFO, WARNING, ERROR).
LOG_LEVEL=INFO

# Optional: enable error reporting to Sentry. Leave unset to disable.
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0

# =====================================================
# PUSH NOTIFICATIONS (Firebase Cloud Messaging)
# =====================================================

# Path to a Firebase service-account JSON key file (from Firebase Console >
# Project Settings > Service Accounts > Generate new private key). Push
# sending is a no-op until this is set. See users/push.py and
# mobile/README.md for the mobile-side setup.
FIREBASE_CREDENTIALS_PATH=

# =====================================================
# DUE-DATE REMINDERS
# =====================================================

# How many hours before a Fakra's due_date a one-time reminder is sent, and
# how often (in minutes) the in-process scheduler checks for due Fakras.
# See fakras/reminders.py and fakras/apps.py.
FAKRA_REMINDER_WINDOW_HOURS=24
FAKRA_REMINDER_CHECK_INTERVAL_MINUTES=60

# =====================================================
# RECURRING FAKRAS
# =====================================================

# How often (in minutes) the in-process scheduler checks for overdue
# recurring Fakras and creates their next occurrence. See
# fakras/recurrence.py and fakras/apps.py.
FAKRA_RECURRENCE_CHECK_INTERVAL_MINUTES=60

# =====================================================
# AI SMART ADD
# =====================================================

# Google Gemini API key used to turn free text (e.g. "milk, eggs, and bread")
# into structured items. Smart Add is a no-op until this is set. Get a free
# key from https://aistudio.google.com/apikey. See fakras/ai.py.
GEMINI_API_KEY=

# Which Gemini model to use for Smart Add. Defaults to gemini-2.5-flash,
# which has a free tier well suited to this kind of extraction task.
GEMINI_MODEL=gemini-2.5-flash
